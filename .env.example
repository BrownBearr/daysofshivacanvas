# Public base URL of the Backblaze B2 bucket holding full-quality source clips.
# Exposed in the client bundle (VITE_ prefix), so it must NOT contain secrets.
# In production (Vercel), set this in the project's Environment Variables instead of committing it.
VITE_CDN_BASE=https://daysofshiva-source.s3.us-east-005.backblazeb2.com

# --- Upload script only (NOT VITE_ prefixed; never reaches the browser) ---
# These are read by a Node upload script and must stay secret. Put real values in .env.local
# B2_KEY_ID=
# B2_APP_KEY=
# B2_BUCKET=daysofshiva-source
# B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
# B2_REGION=us-east-005
